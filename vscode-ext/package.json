{
  "name": "martina-vscode",
  "displayName": "Martina",
  "description": "Tracks engaged coding time per file and reports to the local martina daemon.",
  "version": "0.1.1",
  "publisher": "martina",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/martina/martina"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "martina.showLog",
        "title": "Martina: Show Log"
      },
      {
        "command": "martina.sendTestEvent",
        "title": "Martina: Send Test Event Now"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node --test",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.26.0",
    "typescript": "^5.4.5"
  }
}

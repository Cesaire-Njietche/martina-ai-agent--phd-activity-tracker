{
  "name": "phd-tracker-ext",
  "displayName": "PhD Research Tracker",
  "version": "0.1.0",
  "description": "Tracks engaged reading time on paper pages and reports to the local phd-tracker daemon.",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "postbuild": "node scripts/fix-reserved-names.mjs",
    "package": "plasmo package",
    "test": "vitest run"
  },
  "dependencies": {
    "pdfjs-dist": "4.4.168",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "0.0.260",
    "@types/node": "20.11.30",
    "@types/react": "18.2.79",
    "@types/react-dom": "18.2.25",
    "typescript": "5.4.5",
    "vitest": "1.5.0"
  },
  "manifest": {
    "host_permissions": [
      "http://localhost:5699/*",
      "https://arxiv.org/*"
    ],
    "permissions": [
      "storage",
      "alarms",
      "declarativeNetRequest"
    ],
    "web_accessible_resources": [
      {
        "resources": ["tabs/pdf-viewer.html"],
        "matches": ["https://arxiv.org/*"]
      }
    ]
  }
}
